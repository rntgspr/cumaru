#!/usr/bin/env bash
# cumaru — minimal CLI for the .cumaru/ framework
#
# Entry point. Subcommands live as individual scripts under src/, sourced
# at startup. The dispatch at the bottom routes argv to the matching
# cmd_<name> function.
#
# Subcommands:
#   doctor [--quiet]              run health checks on the .cumaru/ tree (default)
#   install [--domain <name>] [--with <s>...]  install a domain into a project
#   intake <KEY>                  fetch a tracker issue and mirror it under .cumaru/intake/
#   update [...]                  update .cumaru/ files, skills, and slash commands from source
#   upgrade                       re-run the install script (replaces ~/.cumaru wholesale)
#   flow <src> <verb> [<dst>]     safe file ops inside .cumaru/ (move/copy/create/remove)
#   tag [<file> [<tag>]]          read/write/audit <!-- cumaru:NAME --> blocks
#   coverage [--refs|--gaps|--rows] [--strict]  report spec↔code reference coverage
#   tree [<directory-or-md>] [--deep] [--rows]  list filesystem-backed navigation candidates
#   migrate [--apply]             migrate a project tree from llm (legacy) to cumaru
#   help                          print top-level help
#
# Note: there is no `reconcile` subcommand — orphan detection is a check
# inside `cumaru doctor` (raiz + pilares declared by root.entities in schema).
#
# Exit codes:
#   0 — success
#   1 — runtime error (validate found errors; subcommand specific)
#   2 — usage error

set -uo pipefail

# Resolve the real location of this script, following symlinks. Any global
# symlink (e.g. ~/.local/bin/llm → /path/to/dot-llm/llm) resolves back to
# the real checkout so SCRIPT_DIR points at the dot-llm repo, where src/,
# domains/ (including __base/) live.
_resolve_self() {
  local p="$1" n=0
  while [[ -L "$p" ]]; do
    # Cap the chain so a circular symlink on PATH (a→b→a) fails loudly instead
    # of hanging the CLI forever at startup.
    if (( ++n > 40 )); then
      printf 'cumaru: too many symlink levels resolving %s (cycle?)\n' "$1" >&2
      return 1
    fi
    local link
    link="$(readlink "$p")"
    case "$link" in
      /*) p="$link" ;;
      *)  p="$(dirname "$p")/$link" ;;
    esac
  done
  printf '%s\n' "$(cd "$(dirname "$p")" && pwd)"
}
SCRIPT_DIR="$(_resolve_self "${BASH_SOURCE[0]}")"
SRC="$SCRIPT_DIR/src"
# SKILLS_SRC holds opt-in skills (--with <name>) only. Universal cumaru-*
# skills + every slash command live INSIDE each domain at
# domains/<domain>/{skills,commands}/ and are sourced from there.
SKILLS_SRC="$SCRIPT_DIR/skills"

# Multi-domain layout: all domains (including the minimal kernel) live under
# `domains/`. The kernel is `domains/__base/`; pre-built domains are
# `domains/<name>/`. Each domain is fully self-contained (its own schema +
# starter files); the adopter installs one.
DOMAINS_DIR="$SCRIPT_DIR/domains"
BASE_DOMAIN_SRC="$DOMAINS_DIR/__base"
DEFAULT_DOMAIN="sdlc-full"
# DOMAIN_SRC resolves at command time via _resolve_domain_src; defaults
# below preserve the prior single-source behaviour for modules that only need
# templates/roles (e.g. cmd_install reads it; cmd_update resolves its own).
DOMAIN_SRC="$DOMAINS_DIR/$DEFAULT_DOMAIN"

# Resolve a domain name (or `base`) to its source directory. Echoes the
# path on success; returns 1 with an error on stderr if unknown. Empty arg
# defaults to $DEFAULT_FRAMEWORK.
_resolve_domain_src() {
  local name="${1:-$DEFAULT_DOMAIN}"
  case "$name" in
    base) printf '%s\n' "$BASE_DOMAIN_SRC" ;;
    *)
      local p="$DOMAINS_DIR/$name"
      if [[ -d "$p" ]]; then
        printf '%s\n' "$p"
      else
        printf '✗ unknown domain: %s (looked in %s)\n' "$name" "$DOMAINS_DIR" >&2
        return 1
      fi
      ;;
  esac
}

# --- runtime globals consumed by the sourced subcommands ---
QUIET=0
errors=0
warnings=0

# --- load modules ---
# common.sh first (provides red/green/say used by every other module).
# shellcheck source=src/common.sh
. "$SRC/common.sh"
# shellcheck source=src/cmd_help.sh
. "$SRC/cmd_help.sh"
# shellcheck source=src/cmd_install.sh
. "$SRC/cmd_install.sh"
# shellcheck source=src/cmd_uninstall.sh
. "$SRC/cmd_uninstall.sh"
# shellcheck source=src/cmd_doctor.sh
. "$SRC/cmd_doctor.sh"
# shellcheck source=src/cmd_doctor_v6.sh
. "$SRC/cmd_doctor_v6.sh"
# shellcheck source=src/cmd_update.sh
. "$SRC/cmd_update.sh"
# shellcheck source=src/cmd_intake.sh
. "$SRC/cmd_intake.sh"
# shellcheck source=src/cmd_flow.sh
. "$SRC/cmd_flow.sh"
# shellcheck source=src/cmd_tag.sh
. "$SRC/cmd_tag.sh"
# shellcheck source=src/cmd_coverage.sh
. "$SRC/cmd_coverage.sh"
# shellcheck source=src/cmd_tree.sh
. "$SRC/cmd_tree.sh"
# shellcheck source=src/cmd_migrate.sh
. "$SRC/cmd_migrate.sh"
# shellcheck source=src/cmd_migrate_v6.sh
. "$SRC/cmd_migrate_v6.sh"
# shellcheck source=src/cmd_domains.sh
. "$SRC/cmd_domains.sh"

# --- argument dispatch ---
sub="${1:-doctor}"
case "$sub" in
  help|-h|--help)
    cmd_help
    exit 0
    ;;
  install)
    shift
    cmd_install "$@"
    exit $?
    ;;
  uninstall)
    shift
    cmd_uninstall "$@"
    exit $?
    ;;
  update)
    shift
    cmd_update "$@"
    exit $?
    ;;
  upgrade)
    # Upgrading the tool itself IS re-running the install script — it wipes
    # and re-clones the snapshot, then verifies kernel integrity. exec so the
    # old (possibly stale) sourced modules don't outlive the swap.
    exec bash "$SRC/install.sh"
    ;;
  intake)
    shift
    cmd_intake "$@"
    exit $?
    ;;
  flow)
    shift
    cmd_flow "$@"
    exit $?
    ;;
  tag)
    shift
    cmd_tag "$@"
    exit $?
    ;;
  coverage)
    shift
    cmd_coverage "$@"
    exit $?
    ;;
  tree)
    shift
    cmd_tree "$@"
    exit $?
    ;;
  migrate)
    shift
    if [[ "${1:-}" == "v6" ]]; then shift; cmd_migrate_v6 "$@"; else cmd_migrate "$@"; fi
    exit $?
    ;;
  domains)
    cmd_domains
    exit 0
    ;;
  doctor)
    shift
    for arg in "$@"; do
      case "$arg" in
        -h|--help|help) cmd_doctor_help; exit 0 ;;
        --quiet)        QUIET=1 ;;
        -*) red "Unknown flag: $arg"; cmd_doctor_help; exit 2 ;;
        *)  red "Unexpected argument: $arg"; cmd_doctor_help; exit 2 ;;
      esac
    done
    cmd_doctor
    exit $?
    ;;
  --quiet)
    QUIET=1
    cmd_doctor
    exit $?
    ;;
  *)
    red "Unknown subcommand: $sub"
    cmd_help
    exit 2
    ;;
esac
