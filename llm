#!/usr/bin/env bash
# llm — minimal CLI for the .llm/ framework
#
# Entry point. Subcommands live as individual scripts under src/, sourced
# at startup. The dispatch at the bottom routes argv to the matching
# cmd_<name> function.
#
# Subcommands:
#   doctor [--quiet]              run health checks on the .llm/ tree (default)
#   install [DIR] [--with <s>...] install the framework starter into a project
#   intake <KEY>                  fetch a Jira issue and mirror it under .llm/intake/
#   sync [...]                    update .llm/ from a fresh framework source
#   archive <PLAN-ID>             prepare a plan for archival (phase 1)
#   archive finalize <PLAN-ID>    finalize archival after deltas absorbed (phase 2)
#   regen index [pillar]          regenerate a pillar's shallow index
#   regen <JIRA-KEY|slug>         chain-check report (intake → plan → archive → specs)
#   specs bootstrap|deep|consolidate   spec area discovery / delta absorption
#   help                          print top-level help
#
# Exit codes:
#   0 — success
#   1 — runtime error (validate found errors; subcommand specific)
#   2 — usage error

set -uo pipefail

# Resolve the real location of this script, following symlinks. Any global
# symlink (e.g. ~/.local/bin/llm → /path/to/dot-llm/llm) resolves back to
# the real checkout so SCRIPT_DIR points at the dot-llm repo, where src/
# and dot-llm-framework/ live.
_resolve_self() {
  local p="$1"
  while [[ -L "$p" ]]; do
    local link
    link="$(readlink "$p")"
    case "$link" in
      /*) p="$link" ;;
      *)  p="$(dirname "$p")/$link" ;;
    esac
  done
  printf '%s\n' "$(cd "$(dirname "$p")" && pwd)"
}
SCRIPT_DIR="$(_resolve_self "${BASH_SOURCE[0]}")"
SRC="$SCRIPT_DIR/src"
FRAMEWORK_SRC="$SCRIPT_DIR/dot-llm-framework"
SKILLS_SRC="$SCRIPT_DIR/skills"
COMMANDS_SRC="$SCRIPT_DIR/commands"

# --- runtime globals consumed by the sourced subcommands ---
DOT_LLM_DIR="${DOT_LLM_DIR:-.llm}"
SCHEMA="$DOT_LLM_DIR/schema.yaml"
QUIET=0
errors=0
warnings=0

# --- load modules ---
# common.sh first (provides red/green/say used by every other module).
# shellcheck source=src/common.sh
. "$SRC/common.sh"
# shellcheck source=src/cmd_help.sh
. "$SRC/cmd_help.sh"
# shellcheck source=src/cmd_install.sh
. "$SRC/cmd_install.sh"
# shellcheck source=src/cmd_uninstall.sh
. "$SRC/cmd_uninstall.sh"
# shellcheck source=src/cmd_doctor.sh
. "$SRC/cmd_doctor.sh"
# shellcheck source=src/cmd_sync.sh
. "$SRC/cmd_sync.sh"
# shellcheck source=src/cmd_intake.sh
. "$SRC/cmd_intake.sh"
# shellcheck source=src/cmd_specs.sh
. "$SRC/cmd_specs.sh"
# shellcheck source=src/cmd_archive.sh
. "$SRC/cmd_archive.sh"
# shellcheck source=src/cmd_regen.sh
. "$SRC/cmd_regen.sh"
# shellcheck source=src/cmd_tag.sh
. "$SRC/cmd_tag.sh"

# --- argument dispatch ---
sub="${1:-doctor}"
case "$sub" in
  help|-h|--help)
    cmd_help
    exit 0
    ;;
  install)
    shift
    cmd_install "$@"
    exit $?
    ;;
  uninstall)
    shift
    cmd_uninstall "$@"
    exit $?
    ;;
  sync)
    shift
    cmd_sync "$@"
    exit $?
    ;;
  intake)
    shift
    cmd_intake "$@"
    exit $?
    ;;
  specs)
    shift
    spec_sub="${1:-help}"
    shift || true
    case "$spec_sub" in
      bootstrap)      cmd_specs_bootstrap "$@"; exit $? ;;
      deep)           cmd_specs_deep "$@"; exit $? ;;
      consolidate)    cmd_specs_consolidate "$@"; exit $? ;;
      help|-h|--help) cmd_specs_help; exit 0 ;;
      *) red "Unknown specs subcommand: $spec_sub"; cmd_specs_help; exit 2 ;;
    esac
    ;;
  archive)
    shift
    cmd_archive "$@"
    exit $?
    ;;
  regen)
    shift
    cmd_regen "$@"
    exit $?
    ;;
  tag)
    shift
    cmd_tag "$@"
    exit $?
    ;;
  doctor)
    shift
    for arg in "$@"; do
      case "$arg" in
        -h|--help|help) cmd_doctor_help; exit 0 ;;
        --quiet)        QUIET=1 ;;
      esac
    done
    cmd_doctor
    exit $?
    ;;
  --quiet)
    QUIET=1
    cmd_doctor
    exit $?
    ;;
  *)
    red "Unknown subcommand: $sub"
    cmd_help
    exit 2
    ;;
esac
